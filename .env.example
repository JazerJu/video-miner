# VidGo Environment Configuration Example
# Copy this file to .env and configure for your deployment

# Optional public origin for browser/MCP clients.
# This only extends CORS, CSRF, ALLOWED_HOSTS, and MCP origin checks; it does
# not configure Nginx routing or decide which port VidGo listens on.
# VIDGO_URL=https://video.example.com
# Host port mapped to the container's internal 8080 web port.
VIDGO_PORT=8010

# Optional remote MCP endpoint. The main VidGo web/API process still runs
# through WSGI; enabling MCP starts a small ASGI process in the same container.
ENABLE_MCP=0
VIDGO_MCP_PORT=8787
# Set this only when MCP clients use a non-localhost IP/domain or reverse proxy.
# VIDGO_MCP_PUBLIC_URL=http://localhost:8787
# MCP tools call the main VidGo API for long-running task submission/polling.
# In the default single-container setup this is the main app's internal port.
VIDGO_INTERNAL_API_BASE=http://127.0.0.1:8080
# Optional: add extra MCP hosts/origins not covered by VIDGO_URL or
# VIDGO_MCP_PUBLIC_URL.
# VIDGO_MCP_ALLOWED_HOSTS=192.168.1.20:*,video.example.com:*
# VIDGO_MCP_ALLOWED_ORIGINS=http://192.168.1.20:*,https://video.example.com:*

# Docker bind mounts are fixed in docker-compose.yml:
#   ./data/videos.db -> /app/database/videos.db
#   ./data/media     -> /app/media
#   ./data/config    -> /app/config
#   ./data/models    -> /app/models
#
# Model root mounted to /app/models.
# Expected layout:
#   ./data/models/minicpm-v4.5/
#   ./data/models/glm-ocr/
#   ./data/models/embedding/
#   ./data/models/fun-asr/
#   ./data/models/glm-asr/

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Or configure individually:

# Django ALLOWED_HOSTS. The image default is "*" for simple local/Docker use.
# Set this in production to restrict accepted Host headers.
# VIDGO_ALLOWED_HOSTS=video.example.com,localhost,127.0.0.1

# Optional extra CORS/CSRF origins. VIDGO_URL is already added automatically.
# VIDGO_CORS_ALLOWED_ORIGINS=https://frontend.example.com
# VIDGO_CSRF_TRUSTED_ORIGINS=https://frontend.example.com
APP_CONFIG_DIR=/app/config

# Model download/cache endpoints
HF_ENDPOINT=https://hf-mirror.com
HUGGINGFACE_HUB_CACHE=/app/models/.cache/huggingface

# VidUnder local model runtime
VIDUNDER_MODEL_ROOT=/app/models
VIDUNDER_ASR_MODELS_ROOT=/app/models
VIDUNDER_N_CTX=4096
VIDUNDER_N_GPU_LAYERS=99
VIDUNDER_GLM_OCR_N_GPU_LAYERS=17
VIDUNDER_N_BATCH=512
VIDUNDER_KV_CACHE_TYPE=q4_0
VIDUNDER_ONNX_PROVIDER=cuda
VIDUNDER_THINKING_BUDGET=low
VIDUNDER_HWACCEL=none

# GLM-OCR runtime.
# Default keeps ONNX on CPU in the main process for maximum stability.
# To isolate ONNX CUDA from llama.cpp CUDA/cuBLAS, use:
#   VIDUNDER_GLM_OCR_MODE=cuda_isolated
#   VIDUNDER_GLM_OCR_ONNX_PROVIDER=cuda
VIDUNDER_GLM_OCR_MODE=cpu
VIDUNDER_GLM_OCR_ONNX_PROVIDER=cpu
VIDUNDER_GLM_OCR_ONNX_PRECISION=q4
VIDUNDER_GLM_OCR_ONNX_THREADS=4
VIDUNDER_GLM_OCR_WORKER_TIMEOUT=180

# FunASR-GGUF engine code path inside the container.
# FunASR model files are expected under /app/models/fun-asr.
FUNASR_GGUF_DIR=/app/asr_utils/fun-asr-stack

# GLM-ASR Stack paths inside the container.
GLM_ASR_STACK_ROOT=/app/asr_utils/glm-asr-stack
GLM_ASR_MODEL_CACHE=/app/models/glm-asr
GLM_ASR_MODEL=/app/models/glm-asr/glm-asr-nano-2512
GLM_ASR_MODEL_DIR=/app/models/glm-asr/glm-asr-nano-2512
GLM_ASR_FA_MODEL=/app/models/glm-asr/qwen3-forcealigner-0.6b
GLM_ASR_MEL=/app/asr_utils/glm-asr-stack/resources/mel_filters.bin

# GLM-ASR native infer-engine knobs.
GLMASR_VRAM_UTIL=0.9
GLMASR_MAX_SEQS=256
GLMASR_MAX_BATCHED_TOKENS=10000
GLMASR_MAX_NEW_TOKENS=256
GLMASR_ENCODER_FA_PIPELINED=1
GLMASR_ENCODER_FA_VLLM=1
GLMASR_ENCODER_FA_LONG_MIN_SEQ=1
GLMASR_ENCODER_FA_MIN_SEQ=1
# Set only if auto-detection picks the wrong binary, e.g. 120 for RTX 50 series.
GLMASR_GPU_COMPUTE_CAP=

# Optional proxy for downloads/API access from inside the container.
# Use host.docker.internal instead of 127.0.0.1 when the proxy runs on the host.
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Django settings
# SECRET_KEY=your-secret-key-here
# DEBUG=False

# Whisper model directory (optional)
# WHISPER_MODEL_DIR=/path/to/whisper/models

# ============================================
# 邮件服务配置（用于密码重置等功能）
# ============================================

# 发件人邮箱地址（显示在邮件中的"From"字段）
# 示例: noreply@yourdomain.com 或 admin@vidgo.local
DEFAULT_FROM_EMAIL=noreply@vidgo.local

# 邮件后端类型
# - 开发环境: django.core.mail.backends.console.EmailBackend (输出到控制台，不真正发送)
# - 生产环境: django.core.mail.backends.smtp.EmailBackend (通过SMTP真实发送)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP 服务器配置（生产环境必需，开发环境可忽略）
# Gmail: smtp.gmail.com | QQ邮箱: smtp.qq.com | 163邮箱: smtp.163.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# SMTP 登录凭据（生产环境必需）
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# 密码重置链接有效期（秒，默认1小时）
PASSWORD_RESET_TIMEOUT=3600

# --------------------------------------------
# 常用邮箱配置示例（取消注释并修改使用）
# --------------------------------------------

# 【Gmail 示例】需要在 Google 账户中生成"应用专用密码"
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password-16chars
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# 【QQ邮箱示例】需要在邮箱设置中开启 SMTP 并获取授权码
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.qq.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=123456789@qq.com
# EMAIL_HOST_PASSWORD=your-auth-code
# DEFAULT_FROM_EMAIL=123456789@qq.com

# 【163邮箱示例】
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.163.com
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=your-email@163.com
# EMAIL_HOST_PASSWORD=your-auth-code
# DEFAULT_FROM_EMAIL=your-email@163.com
